# ============================================================
# Epigram 환경변수 예시 파일
# 실제 값을 채워 .env.local 로 복사하여 사용한다.
# 이 파일은 git에 커밋된다 — 실제 시크릿을 절대 입력하지 않는다.
# ============================================================

# ----------------------------------------------------------
# 서버 전용 (클라이언트 번들에 포함되지 않음)
# ----------------------------------------------------------

# 외부 백엔드 API 베이스 URL (BFF 프록시에서 사용)
BACKEND_URL=https://your-backend-url.com

# 백엔드 API 경로에 포함되는 팀 ID
# 예: /api/{TEAM_ID}/epigrams
TEAM_ID=your-team-id

# 카카오 OAuth REST API 키 (서버 측 토큰 교환용)
KAKAO_CLIENT_ID=your-kakao-rest-api-key

# 카카오 OAuth 인가 코드 콜백 URI (카카오 앱 설정과 일치해야 함)
# 예: http://localhost:3000/oauth/callback/kakao
KAKAO_REDIRECT_URI=http://localhost:3000/oauth/callback/kakao

# ----------------------------------------------------------
# 클라이언트 공개 (NEXT_PUBLIC_ 접두사 — 브라우저에 노출됨)
# ----------------------------------------------------------

# 클라이언트에서 카카오 OAuth 인가 URL 구성에 사용하는 REST API 키
NEXT_PUBLIC_KAKAO_CLIENT_ID=your-kakao-rest-api-key

# 클라이언트에서 BFF를 호출할 때 사용하는 베이스 URL
# 개발: http://localhost:3000  /  운영: https://your-domain.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000
